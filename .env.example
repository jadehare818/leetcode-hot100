# 飞书推送凭证。复制此文件为 .env 并填入你的值。
# .env 已在 .gitignore 里，不进版本控制。
#
# 两种模式二选一（也可都填，图片模式失败会 fallback 到 webhook）：

# ============================================================
# 图片模式（推荐）：飞书自建应用发 image 消息（打卡卡片 PNG）
# 需要在飞书开放平台建自建应用，拿到 APP_ID + APP_SECRET，
# 并从飞书群里拿到 chat_id（open_chat_id 或 chat_id 均可）。
# 同时需要 pip install playwright + playwright install chromium。
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_TARGET_CHAT=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Webhook 模式（简单）：飞书群自定义机器人发文本消息
# 群设置 → 群机器人 → 添加自定义机器人，勾选签名校验，
# 拿到 webhook URL + secret 填入下面。
# ============================================================
FEISHU_WEBHOOK=https://open.larkoffice.com/open-apis/bot/v2/hook/YOUR_HOOK_ID
FEISHU_SECRET=YOUR_SECRET
